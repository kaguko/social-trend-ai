# Copy file này thành .env rồi điền API key của bạn
# cp .env.example .env

# YouTube Data API v3
# Lấy miễn phí tại: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# (Tuỳ chọn) Các API key khác trong tương lai
# FACEBOOK_ACCESS_TOKEN=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
