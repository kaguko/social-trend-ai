# ============================================================
# HƯỚNG DẪN:
# 1. Copy file này thành .env:
#       cp .env.example .env        (Mac/Linux)
#       copy .env.example .env      (Windows)
# 2. Điền API key thật của bạn vào file .env
# 3. File .env đã bị chặn bởi .gitignore — KHÔNG bao giờ push lên GitHub
# ============================================================

# ------------------------------------------------------------
# YouTube Data API v3 (miễn phí, cần thiết cho youtube_crawler)
# Lấy tại: https://console.cloud.google.com/
# Hướng dẫn: https://developers.google.com/youtube/v3/getting-started
# ------------------------------------------------------------
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# ------------------------------------------------------------
# Gemini API (nếu muốn dùng AI phân tích nâng cao)
# Lấy miễn phí tại: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ------------------------------------------------------------
# OpenAI API (tuỳ chọn, nếu muốn dùng GPT)
# Lấy tại: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ------------------------------------------------------------
# Reddit API (tuỳ chọn, crawl Reddit)
# Đăng ký app tại: https://www.reddit.com/prefs/apps
# ------------------------------------------------------------
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
REDDIT_USER_AGENT=social-trend-ai/1.0
